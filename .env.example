# --- AUTHENTICATION ---
# The master password to log in as Admin. Defaults to 'gossipadmin123' if not set.
ADMIN_PASSWORD=gossipadmin123

# A secure random string used to sign session cookies.
JWT_SECRET=your_jwt_secret_key_here

# --- VERCEL KV CONFIGURATION (Auto-injected by Vercel when linked) ---
# The application automatically falls back to a local JSON file (gossip_mock_db.json)
# during local development if these environment variables are missing.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
